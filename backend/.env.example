# OpenRouter API Configuration
# Get your API key from: https://openrouter.ai/keys
# Note: The default values below use OpenRouter's free trial key and free model

# OpenRouter API Key (defaults to free trial key if not set)
OPENROUTER_API_KEY=sk-or-v1-free-trial-key

# Model to use (defaults to free Llama model)
OPENROUTER_MODEL=meta-llama/llama-3.2-3b-instruct:free

# Other free models you can try:
# OPENROUTER_MODEL=google/gemma-2-9b-it:free
# OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free
# OPENROUTER_MODEL=mistralai/mistral-7b-instruct:free
